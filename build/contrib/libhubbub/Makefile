.PHONY : src/utils/string.c.o

src/utils/string.i: src/utils/string.c.i
.PHONY : src/utils/string.i

# target to preprocess a source file
src/utils/string.c.i:
	cd /app/build && $(MAKE) $(MAKESILENT) -f contrib/libhubbub/CMakeFiles/hubbub.dir/build.make contrib/libhubbub/CMakeFiles/hubbub.dir/src/utils/string.c.i
.PHONY : src/utils/string.c.i

src/utils/string.s: src/utils/string.c.s
.PHONY : src/utils/string.s

# target to generate assembly for a file
src/utils/string.c.s:
	cd /app/build && $(MAKE) $(MAKESILENT) -f contrib/libhubbub/CMakeFiles/hubbub.dir/build.make contrib/libhubbub/CMakeFiles/hubbub.dir/src/utils/string.c.s
.PHONY : src/utils/string.c.s

