.PHONY : unicode_gen.c.o

unicode_gen.i: unicode_gen.c.i
.PHONY : unicode_gen.i

# target to preprocess a source file
unicode_gen.c.i:
	cd /app/build && $(MAKE) $(MAKESILENT) -f contrib/quickjs-ng/CMakeFiles/unicode_gen.dir/build.make contrib/quickjs-ng/CMakeFiles/unicode_gen.dir/unicode_gen.c.i
.PHONY : unicode_gen.c.i

unicode_gen.s: unicode_gen.c.s
.PHONY : unicode_gen.s

# target to generate assembly for a file
unicode_gen.c.s:
	cd /app/build && $(MAKE) $(MAKESILENT) -f contrib/quickjs-ng/CMakeFiles/unicode_gen.dir/build.make contrib/quickjs-ng/CMakeFiles/unicode_gen.dir/unicode_gen.c.s
.PHONY : unicode_gen.c.s

