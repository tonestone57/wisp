wisp-qt_autogen: cmake_check_build_system
	$(MAKE) $(MAKESILENT) -f CMakeFiles/Makefile2 wisp-qt_autogen
.PHONY : wisp-qt_autogen

# fast build rule for target.
wisp-qt_autogen/fast:
	$(MAKE) $(MAKESILENT) -f frontends/qt/CMakeFiles/wisp-qt_autogen.dir/build.make frontends/qt/CMakeFiles/wisp-qt_autogen.dir/build
.PHONY : wisp-qt_autogen/fast

