#include "wisp/ipc/ipc.h"
#include <stdlib.h>
#include <stdbool.h>
#include <stdio.h>
#include <string.h>

#if defined(__unix__) || defined(__linux__) || defined(__APPLE__)
    #include <unistd.h>
    #include <sys/stat.h>
#endif

#if defined(__unix__) || defined(__linux__) || defined(__APPLE__)
#include <sys/socket.h>
#include <sys/un.h>
#include <errno.h>

struct ipc_connection {
    int fd;
    char path[256];
    bool is_listener;
};

nserror ipc_init(void) {
    return NSERROR_OK;
}

static void get_socket_path(const char *name, char *path, size_t size) {
    const char *runtime_dir = getenv("XDG_RUNTIME_DIR");
    if (!runtime_dir) runtime_dir = "/tmp";

    snprintf(path, size, "%s/wisp_ipc_%s.sock", runtime_dir, name);
}

nserror ipc_listen(const char *name, struct ipc_connection **conn) {
    int fd = socket(AF_UNIX, SOCK_STREAM, 0);
    if (fd < 0) return NSERROR_INIT_FAILED;

    struct sockaddr_un addr;
    memset(&addr, 0, sizeof(addr));
    addr.sun_family = AF_UNIX;
    get_socket_path(name, addr.sun_path, sizeof(addr.sun_path));

    unlink(addr.sun_path);

    // Temporarily restrict umask to ensure socket is created 0600
    mode_t old_mask = umask(0077);

    if (bind(fd, (struct sockaddr*)&addr, sizeof(addr)) < 0) {
        umask(old_mask);
        close(fd);
        return NSERROR_INIT_FAILED;
    }

    if (listen(fd, 5) < 0) {
        umask(old_mask);
        close(fd);
        return NSERROR_INIT_FAILED;
    }

    chmod(addr.sun_path, 0600);

    *conn = calloc(1, sizeof(struct ipc_connection));
    (*conn)->fd = fd;
    (*conn)->is_listener = true;
    strncpy((*conn)->path, addr.sun_path, sizeof((*conn)->path) - 1);

    return NSERROR_OK;
}

nserror ipc_accept(struct ipc_connection *listener, struct ipc_connection **conn) {
    if (!listener || !listener->is_listener) return NSERROR_BAD_PARAMETER;

    int client_fd = accept(listener->fd, NULL, NULL);
    if (client_fd < 0) return NSERROR_INIT_FAILED;

    *conn = calloc(1, sizeof(struct ipc_connection));
    (*conn)->fd = client_fd;
    (*conn)->is_listener = false;

    return NSERROR_OK;
}

nserror ipc_connect(const char *name, struct ipc_connection **conn) {
    int fd = socket(AF_UNIX, SOCK_STREAM, 0);
    if (fd < 0) return NSERROR_INIT_FAILED;

    struct sockaddr_un addr;
    memset(&addr, 0, sizeof(addr));
    addr.sun_family = AF_UNIX;
    get_socket_path(name, addr.sun_path, sizeof(addr.sun_path));

    if (connect(fd, (struct sockaddr*)&addr, sizeof(addr)) < 0) {
        close(fd);
        return NSERROR_INIT_FAILED;
    }

    *conn = calloc(1, sizeof(struct ipc_connection));
    (*conn)->fd = fd;
    (*conn)->is_listener = false;

    return NSERROR_OK;
}

struct ipc_header {
    uint32_t type;
    uint32_t len;
};

nserror ipc_send(struct ipc_connection *conn, enum ipc_message_type type, const void *data, size_t len) {
    if (!conn) return NSERROR_BAD_PARAMETER;

    struct ipc_header hdr;
    hdr.type = type;
    hdr.len = len;

    if (write(conn->fd, &hdr, sizeof(hdr)) != sizeof(hdr)) return NSERROR_SAVE_FAILED;
    if (len > 0 && write(conn->fd, data, len) != (ssize_t)len) return NSERROR_SAVE_FAILED;

    return NSERROR_OK;
}

nserror ipc_receive(struct ipc_connection *conn, enum ipc_message_type *type, void **data, size_t *len) {
    if (!conn) return NSERROR_BAD_PARAMETER;

    struct ipc_header hdr;
    ssize_t r = read(conn->fd, &hdr, sizeof(hdr));
    if (r == 0) return NSERROR_EOF;
    if (r != sizeof(hdr)) return NSERROR_SAVE_FAILED;

    *type = hdr.type;
    *len = hdr.len;

    if (hdr.len > 0) {
        *data = malloc(hdr.len);
        if (!*data) return NSERROR_NOMEM;

        if (read(conn->fd, *data, hdr.len) != (ssize_t)hdr.len) {
            free(*data);
            *data = NULL;
            return NSERROR_SAVE_FAILED;
        }
    } else {
        *data = NULL;
    }

    return NSERROR_OK;
}

void ipc_close(struct ipc_connection *conn) {
    if (!conn) return;
    close(conn->fd);
    if (conn->is_listener) {
        unlink(conn->path);
    }
    free(conn);
}

#else
// Stub for Windows
struct ipc_connection { int fd; };
nserror ipc_init(void) { return NSERROR_OK; }
nserror ipc_listen(const char *name, struct ipc_connection **conn) { (void)name; (void)conn; return NSERROR_OK; }
nserror ipc_accept(struct ipc_connection *listener, struct ipc_connection **conn) { (void)listener; (void)conn; return NSERROR_OK; }
nserror ipc_connect(const char *name, struct ipc_connection **conn) { (void)name; (void)conn; return NSERROR_OK; }
nserror ipc_send(struct ipc_connection *conn, enum ipc_message_type type, const void *data, size_t len) { (void)conn; (void)type; (void)data; (void)len; return NSERROR_OK; }
nserror ipc_receive(struct ipc_connection *conn, enum ipc_message_type *type, void **data, size_t *len) { (void)conn; (void)type; (void)data; (void)len; return NSERROR_EOF; }
void ipc_close(struct ipc_connection *conn) { (void)conn; }
#endif
